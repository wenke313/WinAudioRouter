root = true

[*.cs]
indent_style = space
indent_size = 4
charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# C# formatting rules
dotnet_sort_system_directives_first = true
dotnet_style_predefined_type_for_locals_parameters_members = true:silent
dotnet_style_predefined_type_for_member_access = true:silent
dotnet_style_object_initializer = true
dotnet_style_collection_initializer = true
dotnet_style_require_accessibility_modifiers = for_non_interface_members:silent
dotnet_style_explicit_default_value_expression_for_struct = true
dotnet_style_prefer_auto_properties = true
dotnet_style_prefer_inferred_tuple_names = true
dotnet_style_prefer_inferred_anonymous_type_member_names = true
dotnet_style_prefer_null_check_over_type_check = true
dotnet_style_prefer_compound_assignment = true

# Code style rules
csharp_style_var_for_built_in_types = true
csharp_style_var_when_type_is_apparent = true
csharp_style_var_elsewhere = true
csharp_style_prefer_null_coalescing_over_assignment = true
csharp_style_prefer_null_coalescing = true
csharp_style_prefer_conditional_expression_over_assignment = true
csharp_style_prefer_conditional_expression_over_return = true
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_constructors = when_on_single_line:silent
csharp_style_expression_bodied_operators = when_on_single_line:silent
csharp_style_expression_bodied_properties = when_on_single_line:silent
csharp_style_expression_bodied_indexers = when_on_single_line:silent
csharp_style_expression_bodied_accessors = when_on_single_line:silent
csharp_style_expression_bodied_lambdas = when_on_single_line:silent
csharp_style_expression_bodied_local_functions = when_on_single_line:silent
csharp_prefer_braces = true
csharp_prefer_simple_default_expression = true
csharp_style_deconstructed_variable_declaration = true
csharp_style_prefer_pattern_matching = true
csharp_style_prefer_local_over_anonymous_function = true
csharp_style_prefer_local_function = true
csharp_style_prefer_readonly_struct = true
csharp_style_prefer_readonly_struct_member = true
csharp_style_inlined_variable_declaration = true
csharp_style_prefer_null_check_over_type_check = true
csharp_style_prefer_foreach_loop_with_explicit_type = true
csharp_prefer_static_local_function = true
csharp_style_prefer_using_declaration = true
csharp_style_prefer_tuple_swap = true

# Naming conventions
dotnet_naming_rule.interface_should_be_begins_with_i.severity = suggestion
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_style.begins_with_i.capitalization = pascal_case
dotnet_naming_style.begins_with_i.required_prefix = I

dotnet_naming_rule.private_field_should_be_pascal_case_with_underscore.severity = suggestion
dotnet_naming_rule.private_field_should_be_pascal_case_with_underscore.symbols = private_fields
dotnet_naming_rule.private_field_should_be_pascal_case_with_underscore.style = pascal_case_with_underscore

dotnet_naming_style.pascal_case_with_underscore.capitalization = pascal_case
dotnet_naming_style.pascal_case_with_underscore.required_prefix = _

dotnet_naming_rule.pascal_case_names.severity = suggestion
dotnet_naming_rule.pascal_case_names.symbols = all
dotnet_naming_rule.pascal_case_names.style = pascal_case

dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.applicable_kinds = field

dotnet_naming_symbols.all.applicable_accessibilities = *
dotnet_naming_symbols.all.applicable_kinds = class,struct,interface,enum,method,property,event,local_function,constant,namespace

dotnet_naming_style.pascal_case.capitalization = pascal_case

[*.xml]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj}]
indent_style = space
indent_size = 2

[*.{props,targets,ruleset,config,nuspec,resx,vsixmanifest,vsct}]
indent_style = space
indent_size = 2

[*.{xaml,axaml}]
indent_style = space
indent_size = 2
