<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WinAudioRouter.App.ViewModels"
             x:Class="WinAudioRouter.App.SettingsPage"
             Title="设置">

    <ContentPage.Resources>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Margin" Value="16,8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="Label">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>
        <Style x:Key="ValueLabel" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="HorizontalOptions" Value="End"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

            <HorizontalStackLayout Grid.Row="0"
                                   Padding="20,16"
                                   Spacing="12"
                                   HorizontalOptions="Fill">
                <Label Text="⚙"
                       FontSize="28"
                       VerticalOptions="Center"/>
                <Label Text="设置"
                       FontSize="24"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}"/>
            </HorizontalStackLayout>

            <BoxView Grid.Row="0"
                     HeightRequest="1"
                     VerticalOptions="End"
                     Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"/>

            <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12">
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="🖥️ 界面设置"
                           Style="{StaticResource SectionTitle}"/>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="字体大小"
                           Style="{StaticResource SettingLabel}"/>
                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding FontSizeDisplay}"
                           Style="{StaticResource ValueLabel}"/>

                    <Slider Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Minimum="12"
                            Maximum="22"
                            Value="{Binding FontSize}"/>

                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="💡 字体大小影响整个应用的文字显示"
                           FontSize="11"
                           Opacity="0.5"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12">
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="🌐 语言"
                           Style="{StaticResource SectionTitle}"/>

                    <Picker Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            SelectedItem="{Binding SelectedLanguage}"
                            HorizontalOptions="Fill">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>简体中文</x:String>
                                <x:String>English</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="💡 语言切换需要重启应用生效"
                           FontSize="11"
                           Opacity="0.5"/>
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource SectionBorder}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12">
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="🚀 启动选项"
                           Style="{StaticResource SectionTitle}"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="开机自启"
                               Style="{StaticResource SettingLabel}"/>
                        <Switch Grid.Column="2"
                                IsToggled="{Binding IsAutoStartEnabled}"
                                HorizontalOptions="End"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource SectionBorder}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12">
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="📡 蓝牙设置"
                           Style="{StaticResource SectionTitle}"/>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="自动重连"
                           Style="{StaticResource SettingLabel}"/>
                    <Switch Grid.Row="1"
                            Grid.Column="1"
                            IsToggled="{Binding IsAutoReconnectEnabled}"
                            HorizontalOptions="End"/>

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Text="扫描超时"
                           Style="{StaticResource SettingLabel}"/>
                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding ScanTimeoutSeconds, StringFormat='{}{0:F0}秒'}"
                           Style="{StaticResource ValueLabel}"/>

                    <Slider Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Minimum="5"
                            Maximum="60"
                            Value="{Binding ScanTimeoutSeconds}"/>

                    <Label Grid.Row="4"
                           Grid.Column="0"
                           Text="重连间隔"
                           Style="{StaticResource SettingLabel}"/>
                    <Label Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding ReconnectIntervalSeconds, StringFormat='{}{0:F0}秒'}"
                           Style="{StaticResource ValueLabel}"/>

                    <Slider Grid.Row="5"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Minimum="10"
                            Maximum="120"
                            Value="{Binding ReconnectIntervalSeconds}"/>
                </Grid>
            </Border>

            <Label Grid.Row="5"
                   Margin="16,12,16,4"
                   Text="📋 关于"
                   Style="{StaticResource SectionTitle}"/>

            <Border Grid.Row="6" Style="{StaticResource SectionBorder}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8"
                      Padding="0">
                    <Label Grid.Row="0"
                           Text="WinAudioRouter v0.0.1"
                           FontSize="15"
                           FontAttributes="Bold"/>
                    <Label Grid.Row="1"
                           Text="Windows 系统级音频路由器"
                           Opacity="0.7"
                           FontSize="13"/>
                    <Label Grid.Row="2"
                           Text=".NET MAUI / WinUI 3 / WASAPI"
                           Opacity="0.5"
                           FontSize="11"/>
                    <Label Grid.Row="3"
                           Text="© 2026 wenke313 | MIT License"
                           Opacity="0.5"
                           FontSize="11"/>
                </Grid>
            </Border>

        </Grid>
    </ScrollView>

</ContentPage>
