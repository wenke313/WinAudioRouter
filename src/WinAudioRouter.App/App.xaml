<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:WinAudioRouter.App"
             xmlns:converters="clr-namespace:WinAudioRouter.App.Converters"
             x:Class="WinAudioRouter.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:VolumeConverter x:Key="VolumeConverter"/>
            <converters:VolumeToColorConverter x:Key="VolumeToColorConverter"/>
            <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
